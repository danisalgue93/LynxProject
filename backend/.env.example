PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Database (use PostgreSQL for production)
STORE_DRIVER=prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lynx_market?schema=public

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=15m
REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
REFRESH_EXPIRY=7d
REQUIRE_EMAIL_VERIFICATION=true

# Two production admins are defined by wallet address. Keep this as a comma-separated list.
ADMIN_WALLETS=9Jga2n3B8bQr1gCJJRE6Ei7XhsntoUQ1bYWJBSZPYr5d,AdminWalletDev22222222222222222222222222222222

# Solana        
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=CiKuW8r71WnTLkGAKvFyYhtV2UhuJ4j8swDPDc8PEXvu
LYNX_MINT=
# Public address of the treasury wallet that receives deposits and signs withdrawals.
TREASURY_WALLET=
# Base58-encoded secret key of the treasury wallet. Required to send real on-chain SOL withdrawals.
TREASURY_SECRET_KEY=
# Server-only secret used to deterministically derive a real Solana address for managed (Magic) accounts. Required for those accounts to receive on-chain SOL withdrawals.
MANAGED_WALLET_SEED=

# Optional machine admin token for backend scripts. Do not use it from the browser.
ADMIN_API_TOKEN=admin-token-change-in-production

# ── Email (Resend) ──────────────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier supports 3000 emails/month
# Without this, email verification and password reset only work in dev mode
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=Lynx Market <noreply@yourdomain.com>
APP_URL=https://yourdomain.com

# ── Error monitoring (Sentry) ───────────────────────────────────────────────────
# Create a Node.js project at https://sentry.io and paste the DSN here
SENTRY_DSN=https://XXXXX@oXXXXX.ingest.sentry.io/XXXXX
