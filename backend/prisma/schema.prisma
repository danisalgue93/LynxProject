generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============= ENUMS =============

enum MarketStatus {
  OPEN
  ACTIVE
  CUT_OFF
  RESOLVED
  EXPIRED
  CANCELLED
}

enum Position {
  YES
  NO
  A
  B
  DRAW
}

enum Currency {
  SOL
  LYNX
  USD
}

enum OrderSide {
  BUY
  SELL
}

enum OrderStatus {
  OPEN
  PARTIAL_FILLED
  FILLED
  CANCELLED
}

enum LedgerType {
  DEPOSIT
  WITHDRAWAL
  TRADE_BUY
  TRADE_SELL
  SETTLEMENT_WIN
  SETTLEMENT_LOSS
  FEE
  REWARD
  STAKE
  UNSTAKE
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

// ============= CORE MODELS =============

model User {
  id                String      @id @default(cuid())
  email             String      @unique
  passwordHash      String?
  displayName       String?
  role              UserRole    @default(USER)
  balance           Decimal     @default(0) @db.Decimal(28, 9)
  kyc_level         Int         @default(0)
  wallets           String[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  // Relations
  positions         UserPosition[]
  orders            Order[]
  ledger            LedgerEntry[]
  duels             Duel[]
  
  @@index([email])
  @@index([role])
}

model LedgerEntry {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type              LedgerType
  amount            Decimal     @db.Decimal(28, 9)
  currency          Currency    @default(SOL)
  description       String
  
  // Linkage
  marketId          String?
  orderId           String?
  settlementId      String?
  
  createdAt         DateTime    @default(now())
  
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ============= MARKET & TRADING =============

model Market {
  id                String        @id @default(cuid())
  title             String
  description       String        @db.Text
  category          String        // "politics", "sports", "crypto", "weather", "entertainment", etc.
  imageUrl          String?
  
  status            MarketStatus  @default(OPEN)
  poolAmount        Decimal       @default(0) @db.Decimal(28, 9)
  yesAmount         Decimal       @default(0) @db.Decimal(28, 9)
  noAmount          Decimal       @default(0) @db.Decimal(28, 9)
  drawAmount        Decimal       @default(0) @db.Decimal(28, 9)
  
  isTernary         Boolean       @default(false)
  currency          Currency      @default(SOL)
  oracleId          String?
  
  createdAt         DateTime      @default(now())
  cutoffAt          DateTime      @default(now())
  resolvedAt        DateTime?
  result            Position?
  
  // Admin
  createdBy         String?
  resolvedBy        String?
  
  positions         UserPosition[]
  orders            Order[]
  duels             Duel[]
  settlement        Settlement?

  @@index([status])
  @@index([category])
  @@index([currency])
  @@index([cutoffAt])
}

model UserPosition {
  id                String    @id @default(cuid())
  marketId          String
  market            Market    @relation(fields: [marketId], references: [id], onDelete: Cascade)
  
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  position          Position
  amount            Decimal   @db.Decimal(28, 9)
  entryPrice        Decimal   @db.Decimal(28, 9)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([marketId, userId, position])
  @@index([userId])
  @@index([marketId])
}

model Order {
  id                String      @id @default(cuid())
  marketId          String
  market            Market      @relation(fields: [marketId], references: [id], onDelete: Cascade)
  
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  position          Position
  side              OrderSide
  amount            Decimal     @db.Decimal(28, 9)
  price             Decimal     @db.Decimal(28, 9)
  filled            Decimal     @default(0) @db.Decimal(28, 9)
  status            OrderStatus @default(OPEN)
  
  createdAt         DateTime    @default(now())
  filledAt          DateTime?

  @@index([userId])
  @@index([marketId])
  @@index([status])
}

model Duel {
  id                String      @id @default(cuid())
  marketId          String
  market            Market      @relation(fields: [marketId], references: [id], onDelete: Cascade)
  
  initiatorId       String
  initiator         User        @relation(fields: [initiatorId], references: [id], onDelete: Cascade)
  
  position          Position
  amount            Decimal     @db.Decimal(28, 9)
  
  createdAt         DateTime    @default(now())
  
  @@index([marketId])
  @@index([initiatorId])
}

// ============= SETTLEMENT =============

model Settlement {
  id                String      @id @default(cuid())
  marketId          String      @unique
  market            Market      @relation(fields: [marketId], references: [id], onDelete: Cascade)
  
  outcome           Position
  totalPool         Decimal     @db.Decimal(28, 9)
  winnerAmount      Decimal     @db.Decimal(28, 9)
  
  // Fees
  feeTotal          Decimal     @db.Decimal(28, 9)
  feeStaking        Decimal     @db.Decimal(28, 9)
  feeTreasury       Decimal     @db.Decimal(28, 9)
  
  // Distributions
  distributions     SettlementDistribution[]
  
  resolvedAt        DateTime    @default(now())
  resolvedBy        String?
  
  @@index([resolvedAt])
}

model SettlementDistribution {
  id                String      @id @default(cuid())
  settlementId      String
  settlement        Settlement  @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  
  userId            String
  position          Position
  originalAmount    Decimal     @db.Decimal(28, 9)
  payout            Decimal     @db.Decimal(28, 9)
  
  createdAt         DateTime    @default(now())
  
  @@index([userId])
  @@index([settlementId])
}

// ============= GOVERNANCE (PROPOSALS) =============

enum ProposalStatus {
  PENDING
  ACTIVE
  PASSED
  REJECTED
  CANCELLED
}

model Proposal {
  id                String      @id @default(cuid())
  title             String
  description       String      @db.Text
  category          String      @default("protocol")
  
  status            ProposalStatus @default(PENDING)
  
  votesYes          Int         @default(0)
  votesNo           Int         @default(0)
  
  createdAt         DateTime    @default(now())
  createdBy         String?
  endAt             DateTime
  
  votes             Vote[]
  
  @@index([status])
}

model Vote {
  id                String      @id @default(cuid())
  proposalId        String
  proposal          Proposal    @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  
  userId            String
  voteType          String      // "yes" or "no"
  
  createdAt         DateTime    @default(now())
  
  @@unique([proposalId, userId])
  @@index([proposalId])
}

// ============= TRANSACTIONS (CRYPTO) =============

model Transaction {
  id                String      @id @default(cuid())
  signature         String      @unique
  wallet            String?
  intent            String      @db.Text
  
  explorerUrl       String?
  status            String      @default("confirmed")
  
  createdAt         DateTime    @default(now())
  
  @@index([signature])
  @@index([wallet])
}

// ============= CANDLES (PRICE HISTORY) =============

model Candle {
  id                String      @id @default(cuid())
  marketId          String
  market            Market      @relation(fields: [marketId], references: [id], onDelete: Cascade)
  
  open              Decimal     @db.Decimal(28, 9)
  high              Decimal     @db.Decimal(28, 9)
  low               Decimal     @db.Decimal(28, 9)
  close             Decimal     @db.Decimal(28, 9)
  volume            Decimal     @db.Decimal(28, 9)
  
  interval          String      // "1m", "5m", "1h", "1d"
  timestamp         DateTime
  
  @@unique([marketId, interval, timestamp])
  @@index([marketId])
  @@index([timestamp])
}

  amount     Decimal  @db.Decimal(28, 9)
  entryPrice Decimal  @default(1) @db.Decimal(28, 9)
  currency   Currency
  claimed    Boolean  @default(false)
  createdAt  DateTime @default(now())
  market     Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([wallet])
  @@index([marketId])
}

model WalletState {
  wallet      String   @id
  solBalance  Decimal  @default(100) @db.Decimal(28, 9)
  lynxBalance Decimal  @default(10000) @db.Decimal(28, 9)
  stakedLynx  Decimal  @default(0) @db.Decimal(28, 9)
  rewardsSol  Decimal  @default(0) @db.Decimal(28, 9)
  totalVolume Decimal  @default(0) @db.Decimal(28, 9)
  wins        Int      @default(0)
  losses      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id        String      @id
  marketId  String?
  pair      String
  owner     String
  side      OrderSide
  position  Position?
  amount    Decimal     @db.Decimal(28, 9)
  remaining Decimal     @db.Decimal(28, 9)
  price     Decimal     @db.Decimal(28, 9)
  currency  Currency
  status    OrderStatus @default(OPEN)
  createdAt DateTime    @default(now())
  market    Market?     @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([pair, status])
  @@index([marketId])
  @@index([owner])
}

model Trade {
  id        String   @id
  marketId  String?
  pair      String
  maker     String?
  taker     String
  side      OrderSide
  position  Position?
  amount    Decimal  @db.Decimal(28, 9)
  price     Decimal  @db.Decimal(28, 9)
  feeAmount Decimal  @default(0) @db.Decimal(28, 9)
  currency  Currency
  createdAt DateTime @default(now())

  @@index([pair])
  @@index([marketId])
}

model Duel {
  id             String     @id
  parentMarketId String
  creator        String
  rival          String?
  amount         Decimal    @db.Decimal(28, 9)
  currency       Currency
  status         DuelStatus @default(OPEN)
  positionA      Position
  positionB      Position?
  type           String     @default("1v1")
  isTernary      Boolean    @default(false)
  protocolSide   Position?
  createdAt      DateTime   @default(now())
  acceptedAt     DateTime?
  resolvedAt     DateTime?
  winner         String?
  market         Market     @relation(fields: [parentMarketId], references: [id], onDelete: Cascade)

  @@index([parentMarketId])
  @@index([status])
}

model Proposal {
  id          String           @id
  title       String
  description String
  status      ProposalStatus   @default(ACTIVE)
  votesYes    Decimal          @default(0) @db.Decimal(28, 9)
  votesNo     Decimal          @default(0) @db.Decimal(28, 9)
  endTime     DateTime
  category    ProposalCategory
  author      String
  votes       ProposalVote[]
}

model ProposalVote {
  id         String   @id
  proposalId String
  wallet     String
  voteType   String
  weight     Decimal  @db.Decimal(28, 9)
  createdAt  DateTime @default(now())
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@unique([proposalId, wallet])
}

model Notification {
  id        String   @id
  wallet    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([wallet, read])
}

model Candle {
  id        String   @id
  symbol    String
  interval  String
  marketId  String?
  time      DateTime
  open      Decimal  @db.Decimal(28, 9)
  high      Decimal  @db.Decimal(28, 9)
  low       Decimal  @db.Decimal(28, 9)
  close     Decimal  @db.Decimal(28, 9)
  volume    Decimal  @db.Decimal(28, 9)
  market    Market?  @relation(fields: [marketId], references: [id], onDelete: SetNull)

  @@unique([symbol, interval, time])
  @@index([symbol, interval])
}

model AppState {
  id        String   @id
  data      Json
  updatedAt DateTime @updatedAt
}
