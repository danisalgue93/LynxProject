# Copy to .env.local. Never commit real secrets.

RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=7hPfrAwhNPJ6Xt7Y3ximBog1EdzfJV31VBTnYQxLRYCy

# Base58-encoded 64-byte Solana secret key for the current ProtocolConfig admin.
# Generate from an id.json with a trusted local script, then store it in a password manager.
ADMIN_KEYPAIR_BS58=replace_me

# Long random values. Examples:
# openssl rand -base64 48
ADMIN_PASSWORD=replace_with_a_long_random_password
SESSION_SECRET=replace_with_at_least_32_random_characters

# Telegram bot used as second factor.
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# Comma-separated host allowlist for the admin app.
# Keep localhost for local use; add your private tunnel host only when needed.
ADMIN_ALLOWED_HOSTS=localhost:3001,127.0.0.1:3001

# Local-only testing helpers. Never enable in production.
ADMIN_DEV_MODE=false
MOCK_MARKETS=false
