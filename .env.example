# ──────────────────────────────────────────────────────────────────────────────
# Lynx Market — Root .env for Docker Compose
# Copy to .env and fill in all required values before running `docker compose up`
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=lynx_market
POSTGRES_USER=lynx
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Backend Auth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_64_char_hex_secret
REFRESH_SECRET=CHANGE_ME_different_64_char_hex_secret
JWT_EXPIRY=15m
REFRESH_EXPIRY=7d

# ── CORS ───────────────────────────────────────────────────────────────────────
# Your production domain (no trailing slash)
CORS_ORIGIN=https://yourdomain.com

# ── Admin ──────────────────────────────────────────────────────────────────────
# Comma-separated Solana wallet addresses for admin access (min 2 in production)
ADMIN_WALLETS=YourAdminWallet1111111111111111111111111111,YourAdminWallet2222222222222222222222222222
# Generate with: openssl rand -hex 32
ADMIN_API_TOKEN=CHANGE_ME_admin_api_token

# ── Solana ─────────────────────────────────────────────────────────────────────
SOLANA_CLUSTER=mainnet-beta
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
PROGRAM_ID=
LYNX_MINT=

# ── Treasury ───────────────────────────────────────────────────────────────────
# The on-chain Solana wallet that holds protocol funds
TREASURY_WALLET=YourTreasuryWalletPublicKey111111111111111111
# Base58-encoded secret key of the treasury wallet (keep offline, rotate regularly)
TREASURY_SECRET_KEY=YourTreasurySecretKeyInBase58
# Random seed for deterministic managed-wallet derivation (generate: openssl rand -hex 32)
MANAGED_WALLET_SEED=CHANGE_ME_random_seed

# ── Frontend (injected at build time into Vite bundle) ─────────────────────────
VITE_MAGIC_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXX
VITE_MOONPAY_API_KEY=pk_live_XXXXXXXXXXXXXXXX
MOONPAY_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXX

# ── Email verification ─────────────────────────────────────────────────────────
REQUIRE_EMAIL_VERIFICATION=true

# ── Email (Resend) ──────────────────────────────────────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=Lynx Market <noreply@yourdomain.com>
APP_URL=https://yourdomain.com

# ── Error monitoring (Sentry) ───────────────────────────────────────────────────
SENTRY_DSN=https://XXXXX@oXXXXX.ingest.sentry.io/XXXXX
VITE_SENTRY_DSN=https://XXXXX@oXXXXX.ingest.sentry.io/XXXXX
