# Backend
# URL of the Lynx Express backend (no trailing slash)
VITE_API_URL=http://localhost:4000

# Solana
# mainnet-beta | devnet | testnet
VITE_SOLANA_NETWORK=mainnet-beta
# Optional custom RPC (Helius, QuickNode, etc.)
# VITE_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Magic Link (email login; Google OAuth needs the Magic OAuth extension package)
# 1. Create an app at https://dashboard.magic.link
# 2. The CDN SDK is loaded in index.html
# 3. Paste your publishable key below
VITE_MAGIC_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXX

# MoonPay (buy SOL/LYNX with credit/debit card)
# 1. Create an account at https://dashboard.moonpay.com
# 2. Paste your publishable key below (use pk_test_ for sandbox)
VITE_MOONPAY_API_KEY=pk_test_XXXXXXXXXXXXXXXX
# Server-only secret used by frontend/server.ts to sign MoonPay widget URLs.
# Never expose this as VITE_ and never put it in client code.
MOONPAY_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXX

# Optional: Gemini AI
# GEMINI_API_KEY=AIzaSy...
